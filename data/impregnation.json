{
  "_description": "Impregnation (apretura) types - FACTORY FORMULA",
  "_source": "Factory razrada artikla spreadsheets + feedback Feb 2026",
  "_version": "3.0 - Mar 2026",
  
  "_factory_formula_structure": {
    "coefficients": ["tip_apreture", "nanos_apreture", "brzina_mjerenja (optional)"],
    "formula": "UKUPNO = tip_apreture × nanos_apreture × brzina_mjerenja",
    "weight_formula": "weight_impreg = weight_raw × nanos_apreture_ratio",
    "breaking_force_formula": "F_impreg = F_raw × UKUPNO (no weave efficiency!)",
    "_note": "Factory does NOT use separate weave efficiency factor"
  },
  
